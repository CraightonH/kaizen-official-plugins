{
  "version": "1.0.0",
  "name": "kaizen-official",
  "description": "Official kaizen plugins and harnesses.",
  "url": "https://github.com/CraightonH/kaizen-official-plugins.git",
  "entries": [
    {
      "kind": "plugin",
      "name": "events",
      "description": "Event vocabulary for the minimum shell harness.",
      "categories": ["events"],
      "versions": [
        {
          "version": "0.1.0",
          "source": { "type": "file", "path": "plugins/events" }
        }
      ]
    },
    {
      "kind": "plugin",
      "name": "shell",
      "description": "TTY passthrough shell (unscoped). Provides shell:exec.",
      "categories": ["shell", "exec"],
      "versions": [
        {
          "version": "0.1.0",
          "source": { "type": "file", "path": "plugins/shell" }
        }
      ]
    },
    {
      "kind": "plugin",
      "name": "driver",
      "description": "Session driver for the minimum shell harness. Loops stdin -> shell:exec.",
      "categories": ["driver"],
      "versions": [
        {
          "version": "0.1.0",
          "source": { "type": "file", "path": "plugins/driver" }
        }
      ]
    },
    {
      "kind": "harness",
      "name": "minimum-shell",
      "description": "Minimum-viable harness: events + driver + shell. No LLM.",
      "categories": ["harness", "shell"],
      "versions": [
        {
          "version": "0.1.0",
          "path": "harnesses/minimum-shell.json"
        }
      ]
    }
  ]
}
